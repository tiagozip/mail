{
  "name": "estrogen-mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev:client": "vite",
    "dev": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "lint": "biome check src",
    "format": "biome format --write src",
    "db:init": "wrangler d1 execute estrogen-mail --remote --file=schema.sql",
    "db:init:local": "wrangler d1 execute estrogen-mail --local --file=schema.sql",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "lettersanitizer": "^1.0.7",
    "openpgp": "^6.3.1",
    "postal-mime": "^2.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-letter": "^0.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^6.4.3",
    "wrangler": "^4.105.0"
  }
}
